{
  "type": "element",
  "canScale": false,

  "canEditSource": false,
  "hideDefaultSettings": true,
  "gizmo": {
    "title": "Page details",
    "description": "Define a visual split between pages which CMSs can use to create pages.",
    "icon": "editor:format-page-break",
    "color": "grey",
    "tags": ["Other"],
    "handles": [],
    "meta": {
      "author": "HAXTheWeb core team",
      "hidden": true
    }
  },
  "settings": {
    "configure": [
      {
        "property": "title",
        "title": "Title",
        "description": "Title shown in the theme and first heading.",
        "inputMethod": "textfield"
      },
      {
        "property": "pageType",
        "title": "Type",
        "description": "Visual page context label.",
        "inputMethod": "select",
        "options": {
          "": "-- none --",
          "content": "Content",
          "assessment": "Assessment",
          "quiz": "Quiz",
          "submission": "Submission",
          "lesson": "Lesson",
          "module": "Module",
          "task": "Task",
          "activity": "Activity",
          "project": "Project",
          "practice": "Practice",
          "unit": "Unit",
          "objectives": "Learning Objectives",
          "connection": "Connection",
          "knowledge": "Did You Know?",
          "strategy": "Learning Strategy",
          "discuss": "Discuss",
          "listen": "Listen",
          "make": "Make",
          "observe": "Observe",
          "present": "Present",
          "reading": "Reading",
          "reflect": "Reflect",
          "research": "Research",
          "watch": "Watch",
          "write": "Write"
        }
      },
      {
        "property": "tags",
        "title": "Tags",
        "description": "Comma-separated list of tags.",
        "inputMethod": "textfield"
      },
      {
        "property": "linkUrl",
        "title": "Link URL",
        "description": "Redirect URL shown instead of page content.",
        "inputMethod": "textfield"
      },
      {
        "property": "linkTarget",
        "title": "Link Target",
        "description": "Open links in the same window or a new window.",
        "inputMethod": "select",
        "options": {
          "_self": "Same window",
          "_blank": "New window"
        }
      }
    ],
    "advanced": [
      {
        "property": "published",
        "title": "Published",
        "description": "Unpublished pages are hidden from end users.",
        "inputMethod": "boolean"
      },
      {
        "property": "locked",
        "title": "Lock page",
        "description": "Lock or unlock all elements on this page.",
        "inputMethod": "boolean"
      },
      {
        "property": "slug",
        "title": "Path",
        "description": "URL slug for this page.",
        "inputMethod": "textfield"
      },
      {
        "property": "image",
        "title": "Media",
        "description": "Media that represents the page, used in some themes and views.",
        "inputMethod": "haxupload",
        "noCamera": true,
        "noVoiceRecord": true
      },
      {
        "property": "parent",
        "title": "Parent",
        "description": "Path of the parent page.",
        "inputMethod": "textfield"
      },
      {
        "property": "noderefs",
        "title": "Related content",
        "description": "Pages related to this page.",
        "inputMethod": "array",
        "itemLabel": "item",
        "hideReorder": true,
        "expanded": false,
        "hideDuplicate": true,
        "properties": [
          {
            "property": "node",
            "title": "Page",
            "description": "Related page.",
            "inputMethod": "textfield"
          }
        ]
      }
    ],
    "developer": [
      {
        "property": "description",
        "title": "Description",
        "description": "Description used in collections and search engine optimization.",
        "inputMethod": "textfield"
      },
      {
        "property": "entityType",
        "title": "Entity Type",
        "description": "Defaults to page unless set otherwise.",
        "inputMethod": "select",
        "options": {
          "page": "Page (default)",
          "taxonomy": "Taxonomy",
          "taxonomyTerm": "Taxonomy Term",
          "region": "Region"
        }
      },
      {
        "property": "icon",
        "title": "Icon",
        "description": "Icon associated with this page in the site.",
        "inputMethod": "iconpicker"
      },
      {
        "property": "accentColor",
        "title": "Accent color",
        "description": "Color associated with this page in the site.",
        "inputMethod": "colorpicker"
      },
      {
        "property": "hideInMenu",
        "title": "Hide in menu",
        "description": "Hide this page from menus while keeping its URL.",
        "inputMethod": "boolean"
      },
      {
        "property": "order",
        "title": "Order",
        "description": "Order relative to sibling pages.",
        "inputMethod": "number"
      },
      {
        "property": "developerTheme",
        "title": "Page theme",
        "description": "Override theme for this page only.",
        "inputMethod": "textfield"
      },
      {
        "property": "author",
        "title": "Author",
        "description": "Username of the last person to modify this page.",
        "inputMethod": "textfield"
      }
    ]
  },
  "saveOptions": {
    "unsetAttributes": [
      "t",
      "_hax-state",
      "element-visible",
      "noderefs",
      "style",
      "resource",
      "prefix"
    ]
  },
  "demoSchema": [
    {
      "tag": "page-break",
      "content": "",
      "properties": {
        "published": true,
        "locked": false,
        "status": "new",
        "title": "New page",
        "data-hax-ray": "Page break"
      }
    }
  ]
}
