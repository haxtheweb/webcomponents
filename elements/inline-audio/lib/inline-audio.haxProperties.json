{
  "canScale": false,

  "canEditSource": true,
  "contentEditable": true,
  "gizmo": {
    "title": "Inline audio",
    "description": "Play audio inline to supplement page content.",
    "icon": "av:volume-up",
    "color": "blue",
    "tags": [
      "Media",
      "media",
      "mp3",
      "sound",
      "audio",
      "inline",
      "enhancement"
    ],
    "handles": [
      {
        "type": "inline",
        "text": "term"
      }
    ],
    "meta": {
      "author": "HAXTheWeb core team",
      "inlineOnly": true
    }
  },
  "settings": {
    "configure": [
      {
        "property": "source",
        "title": "Source",
        "description": "MP3 file or URL.",
        "inputMethod": "haxupload",
        "noCamera": true
      },
      {
        "property": "accentColor",
        "title": "Accent Color",
        "description": "Card accent color.",
        "inputMethod": "colorpicker"
      },
      {
        "property": "shiny",
        "title": "Shiny",
        "description": "Use a lighter accent background instead of gray.",
        "inputMethod": "boolean"
      }
    ],
    "advanced": [
      {
        "property": "dark",
        "title": "Dark",
        "description": "Use dark mode.",
        "inputMethod": "boolean"
      }
    ]
  },
  "saveOptions": {
    "unsetAttributes": ["icon", "playing", "canPlay", "aria"]
  },
  "demoSchema": [
    {
      "tag": "inline-audio",
      "properties": {
        "source": "https://inline-audio-mocha.vercel.app/assets/whopper.mp3",
        "accentColor": "orange"
      },
      "content": "Hear it yourself"
    }
  ]
}
