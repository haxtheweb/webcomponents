{
  "canScale": false,
  "canEditSource": true,
  "type": "grid",
  "designSystem": {
    "accent": true,
    "primary": true
  },
  "editMode": {
    "editMode": true
  },
  "gizmo": {
    "title": "Multiple choice",
    "description": "Multiple-choice self-check question.",
    "icon": "hax:multiple-choice",
    "color": "purple",
    "tags": [
      "Instructional",
      "quiz",
      "form",
      "multiple",
      "self check",
      "test",
      "exam",
      "question",
      "answer",
      "feedback"
    ],
    "handles": [],
    "meta": {
      "author": "HAXTheWeb core team"
    }
  },
  "settings": {
    "configure": [
      {
        "property": "question",
        "title": "Question",
        "description": "Question for users to respond to.",
        "inputMethod": "textfield"
      },
      {
        "property": "randomize",
        "title": "Randomize",
        "description": "Randomize answers dynamically.",
        "inputMethod": "boolean"
      },
      {
        "property": "singleOption",
        "title": "Single answer",
        "description": "Allow only one answer.",
        "inputMethod": "boolean"
      },
      {
        "property": "answers",
        "title": "Answers",
        "inputMethod": "array",
        "itemLabel": "label",
        "hideReorder": true,
        "expanded": false,
        "hideDuplicate": true,
        "properties": [
          {
            "property": "label",
            "title": "Answer",
            "inputMethod": "textfield",
            "required": true
          },
          {
            "property": "correct",
            "title": "Correct",
            "description": "Whether this answer is correct.",
            "inputMethod": "boolean"
          },
          {
            "property": "image",
            "title": "Image",
            "description": "Image shown with this answer.",
            "inputMethod": "haxupload",
            "noVoiceRecord": true,
            "noCamera": true
          },
          {
            "property": "alt",
            "title": "Image Alternative text",
            "description": "Alternative text for the image.",
            "inputMethod": "textfield"
          }
        ]
      }
    ],
    "advanced": [],
    "developer": [
      {
        "property": "quizName",
        "title": "Name of the quiz",
        "description": "Quiz name used for xAPI identification in analytics systems.",
        "inputMethod": "textfield"
      }
    ]
  },
  "saveOptions": {
    "unsetAttributes": [
      "__utils",
      "displayed-answers",
      "colors",
      "answers",
      "show-answer",
      "t",
      "attempts",
      "edit"
    ]
  },
  "demoSchema": [
    {
      "tag": "multiple-choice",
      "properties": {
        "question": "Which is correct?",
        "singleOption": true,
        "randomize": true
      },
      "content": "<input type=\"checkbox\" value=\"Answer 1\" correct>\n<input type=\"checkbox\" value=\"Another potential answer\">"
    }
  ]
}
