{
  "canScale": false,

  "canEditSource": true,
  "gizmo": {
    "title": "Image compare",
    "description": "Swipe one image over another for comparison.",
    "icon": "image:compare",
    "color": "orange",
    "tags": [
      "Media",
      "media",
      "comparison",
      "slider",
      "swipe",
      "compare",
      "instructional"
    ],
    "handles": [
      {
        "type": "image",
        "source": "bottomSrc",
        "source2": "topSrc",
        "title": "title"
      }
    ],
    "meta": {
      "author": "HAXTheWeb core team"
    }
  },
  "settings": {
    "configure": [
      {
        "property": "topSrc",
        "title": "Top image",
        "description": "Top image to swipe over the bottom image.",
        "inputMethod": "haxupload",
        "noVoiceRecord": true,
        "validationType": "url",
        "required": true
      },
      {
        "property": "topAlt",
        "title": "Top image alt text",
        "description": "Required alt text for accessibility.",
        "inputMethod": "alt",
        "required": true
      },
      {
        "property": "bottomSrc",
        "title": "Bottom image",
        "description": "Bottom image shown under the top image.",
        "inputMethod": "haxupload",
        "noVoiceRecord": true,
        "validationType": "url",
        "required": true
      },
      {
        "property": "bottomAlt",
        "title": "Bottom image alt text",
        "description": "Required alt text for accessibility.",
        "inputMethod": "alt",
        "required": true
      }
    ],
    "advanced": [
      {
        "property": "opacity",
        "title": "Behavior",
        "description": "Choose wipe mode (default) or top-image opacity mode.",
        "inputMethod": "boolean",
        "icon": "image:compare"
      },
      {
        "property": "accentColor",
        "title": "Accent Color",
        "inputMethod": "colorpicker",
        "description": "Slider bar color."
      },
      {
        "property": "dark",
        "title": "Dark",
        "inputMethod": "boolean",
        "description": "Invert the slider bar color."
      },
      {
        "property": "position",
        "title": "Initial Position",
        "description": "Starting position from 0 to 100.",
        "inputMethod": "number",
        "min": 0,
        "max": 100
      }
    ]
  },
  "demoSchema": [
    {
      "tag": "image-compare-slider",
      "properties": {
        "opacity": true,
        "topSrc": "https://cdn2.thecatapi.com/images/bjj.jpg",
        "topAlt": "",
        "bottomSrc": "https://cdn2.thecatapi.com/images/9j5.jpg",
        "bottomAlt": ""
      },
      "content": ""
    }
  ]
}
