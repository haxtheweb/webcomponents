        "inputMethod": "textfield"
      },
      {
        "property": "filePath",
        "title": "File Path",
        "description": "File path for StackBlitz embed.",
        "inputMethod": "textfield"
      },
      {
        "property": "hideExplorer",
        "title": "Hide file explorer",
        "description": "Hide the file explorer in StackBlitz.",
        "inputMethod": "boolean"
      },
      {
        "property": "ctl",
        "title": "Click to load StackBlitz",
