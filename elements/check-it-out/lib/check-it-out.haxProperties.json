        "inputMethod": "boolean"
      },
      {
        "property": "view",
        "title": "View",
        "description": "Default StackBlitz view (preview, editor, or both).",
        "inputMethod": "select",
        "options": {
          "preview": "Preview",
          "editor": "Editor",
          "both": "Both"
