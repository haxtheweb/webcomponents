{
  "name": "@haxtheweb/matching-question",
  "wcfactory": {
    "className": "MatchingQuestion",
    "customElementClass": "LitElement",
    "elementName": "matching-question",
    "generator-wcfactory-version": "0.14.0"
  },
  "version": "26.0.0",
  "description": "Match concepts question type",
  "repository": {
    "type": "git",
    "url": "https://github.com/haxtheweb/webcomponents.git"
  },
  "main": "matching-question.js",
  "module": "matching-question.js",
  "scripts": {
    "test": "web-test-runner \"test/**/*.test.js\" --node-resolve --config=../../web-test-runner.config.mjs --playwright --browsers chromium",
    "start": "yarn run dev",
    "build": "gulp --gulpfile=gulpfile.cjs && prettier --ignore-path ../../.prettierignore --write '**/*.{js,json}' && cem analyze --litelement --exclude \"(public|*.stories.js)\" --globs \"{*,lib/**}.js\"",
    "dev": "concurrently --kill-others \"yarn run watch\" \"yarn run serve\"",
    "watch": "gulp dev --gulpfile=gulpfile.cjs",
    "serve": "web-dev-server -c ../../web-dev-server.config.mjs",
    "lighthouse": "gulp lighthouse --gulpfile=gulpfile.cjs",
    "test:watch": "web-test-runner \"test/**/*.test.js\" --node-resolve --config=../../web-test-runner.config.mjs --playwright --browsers chromium --watch"
  },
  "author": {
    "name": ""
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@haxtheweb/multiple-choice": "^26.0.0",
    "lit": "3.3.2"
  },
  "devDependencies": {
    "@haxtheweb/deduping-fix": "^26.0.0",
    "@open-wc/testing": "4.0.0",
    "@web/dev-server": "0.4.6",
    "concurrently": "9.1.2",
    "gulp-babel": "8.0.0",
    "polymer-build": "3.1.4"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "customElements": "custom-elements.json",
