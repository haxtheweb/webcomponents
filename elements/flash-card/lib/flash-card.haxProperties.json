{
  "canScale": false,

  "canEditSource": true,
  "gizmo": {
    "title": "Flash card",
    "description": "Practice concepts with front-and-back flash cards.",
    "icon": "av:call-to-action",
    "color": "blue",
    "tags": ["Instructional", "self check", "flash card", "quiz", "educational"]
  },
  "settings": {
    "configure": [
      {
        "slot": "front",
        "title": "Front of the Card",
        "description": "Front text or question.",
        "inputMethod": "textfield"
      },
      {
        "slot": "back",
        "title": "Back of the Card",
        "description": "Expected answer.",
        "inputMethod": "textfield"
      },
      {
        "property": "imgSource",
        "title": "Image Source",
        "description": "Image file used for the card. Overrides Image Keyword.",
        "inputMethod": "haxupload",
        "noVoiceRecord": true
      }
    ],
    "advanced": [
      {
        "property": "dark",
        "title": "Dark",
        "description": "Use dark mode.",
        "inputMethod": "boolean"
      },
      {
        "property": "accentColor",
        "title": "Accent Color",
        "description": "Card accent color.",
        "inputMethod": "colorpicker"
      },
      {
        "property": "imgKeyword",
        "title": "Image Keyword",
        "description": "Random image keyword. Overridden by Image Source.",
        "inputMethod": "textfield"
      }
    ]
  },
  "demoSchema": [
    {
      "tag": "flash-card",
      "properties": {
        "speak": true,
        "img-source": "https://hips.hearstapps.com/clv.h-cdn.co/assets/15/22/1432664914-strawberry-facts1.jpg",
        "listen": true
      },
      "content": "<p slot='front'>What is strawberry in Spanish</p><p slot='back'>fresa</p>"
    }
  ]
}
