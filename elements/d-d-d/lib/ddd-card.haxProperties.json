{
  "type": "grid",
  "canScale": false,
  "designSystem": {
    "primary": true
  },
  "canEditSource": true,
  "contentEditable": true,
  "hideDefaultSettings": true,
  "gizmo": {
    "title": "Card",
    "description": "Card component styled with the DDD design system.",
    "icon": "chrome-reader-mode",
    "color": "light-blue",
    "tags": ["Layout", "content", "card", "Image"],
    "handles": [
      {
        "type": "image",
        "url": "src"
      }
    ],
    "meta": {
      "author": "HAXTheWeb core team",
      "owner": "The Pennsylvania State University"
    }
  },
  "settings": {
    "configure": [
      {
        "property": "src",
        "title": "Image",
        "description": "Optional image.",
        "inputMethod": "haxupload",
        "noVoiceRecord": true
      },
      {
        "property": "alt",
        "title": "Image alt",
        "description": "Alternative text describing the image.",
        "inputMethod": "alt",
        "noVoiceRecord": true
      },
      {
        "property": "title",
        "title": "Title",
        "description": "Card title.",
        "inputMethod": "textfield"
      },
      {
        "slot": "",
        "title": "Content",
        "description": "Card content area.",
        "inputMethod": "textfield",
        "slotWrapper": "p",
        "allowedSlotWrappers": ["p"]
      },
      {
        "property": "href",
        "title": "Link",
        "description": "Button link URL.",
        "inputMethod": "haxupload",
        "noVoiceRecord": true,
        "noCamera": true
      }
    ],
    "advanced": [
      {
        "property": "label",
        "title": "Label",
        "description": "Button label.",
        "inputMethod": "textfield"
      },
      {
        "property": "noArrow",
        "title": "No Arrow",
        "description": "Hide the button arrow.",
        "inputMethod": "boolean"
      }
    ],
    "developer": [
      {
        "property": "target",
        "title": "Link: target",
        "description": "Where to open the link.",
        "inputMethod": "select",
        "options": {
          "": "Same window",
          "_blank": "New window - _blank",
          "_top": "Top window - _top",
          "_parent": "Parent window - _parent"
        }
      },
      {
        "property": "rel",
        "title": "Link: rel",
        "description": "Relationship between linked resource and current document.",
        "inputMethod": "textfield"
      }
    ]
  },
  "demoSchema": [
    {
      "tag": "ddd-card",
      "properties": {
        "src": "https://placehold.co/400x300",
        "title": "Title",
        "link": "https://hax.cloud"
      },
      "content": "<p>The card content</p>"
    }
  ]
}
