{
  "api": "1",
  "canScale": false,

  "canEditSource": true,
  "contentEditable": false,
  "hideDefaultSettings": true,
  "type": "grid",
  "gizmo": {
    "title": "Page section",
    "description": "Section container for page content and screen-based layouts.",
    "icon": "av:call-to-action",
    "color": "purple",
    "tags": ["Layout", "page", "section", "container", "cta"],
    "handles": [],
    "meta": {
      "author": "HAXTheWeb core team"
    }
  },
  "settings": {
    "configure": [
      {
        "property": "preset",
        "inputMethod": "radio",
        "title": "Design treatment",
        "description": "Preset style that updates related settings.",
        "itemsList": [
          { "value": "custom", "text": "Custom" },
          { "value": "antihero", "text": "Anti-hero" },
          { "value": "antihero-light", "text": "Anti-hero: Light" },
          { "value": "video", "text": "Video" }
        ]
      },
      {
        "property": "image",
        "inputMethod": "haxupload",
        "title": "Image",
        "description": "Background media for the section.",
        "noVoiceRecord": true,
        "noCamera": true
      },
      {
        "property": "bg",
        "inputMethod": "colorpicker",
        "title": "Background color",
        "description": "Background color when no image is set."
      }
    ],
    "advanced": [
      {
        "property": "scroller",
        "inputMethod": "boolean",
        "title": "Scroll button",
        "description": "Show a button that scrolls to the next section."
      },
      {
        "property": "fold",
        "inputMethod": "boolean",
        "title": "Display fold",
        "description": "Show a visual fold at the bottom of the section."
      },
      {
        "property": "full",
        "inputMethod": "boolean",
        "title": "Full screen size",
        "description": "Fill the viewer's screen height."
      },
      {
        "property": "filter",
        "inputMethod": "boolean",
        "title": "Apply Filter",
        "description": "Apply a visual filter to the background image."
      },
      {
        "slot": "",
        "inputMethod": "textfield",
        "description": "Section content.",
        "title": "Content"
      },
      {
        "slot": "entice",
        "title": "Entice",
        "description": "Optional enticement content.",
        "inputMethod": "textfield"
      },
      {
        "slot": "buttons",
        "title": "Buttons",
        "description": "Button group shown below the text.",
        "inputMethod": "textfield"
      }
    ],
    "developer": [
      {
        "property": "anchor",
        "inputMethod": "textfield",
        "title": "Anchor text",
        "description": "Anchor label shown in navigation."
      }
    ]
  },
  "saveOptions": {
    "unsetAttributes": ["colors"]
  },
  "documentation": {
    "howTo": null,
    "purpose": null
  },
  "demoSchema": [
    {
      "tag": "page-section",
      "content": "<h2>Sharp looking section</h2><hr/><p>This is some sharp looking, well presented content</p><simple-cta hotline filled outlined slot=\"buttons\">Really sharp</simple-cta>",
      "properties": {
        "preset": "antihero",
        "filter": true,
        "bg": "light-blue",
        "full": true,
        "fold": true,
        "scroller": true
      }
    }
  ]
}
