{
  "api": "1",
  "type": "element",
  "editingElement": "core",
  "hideDefaultSettings": false,
  "canScale": false,
  "canEditSource": true,
  "contentEditable": false,
  "gizmo": {
    "title": "RunKit embed",
    "description": "",
    "icon": "hax:code",
    "color": "red",
    "tags": ["Other", "runkit", "code"],
    "handles": [],
