          "default": "default",
          "endpoint": "endpoint"
        }
      },
      {
        "property": "nodeVersion",
        "title": "Node Version",
        "description": "Node.js version (semver).",
        "inputMethod": "textfield"
      }
    ],
    "advanced": [],
    "developer": []
  },
  "saveOptions": {
    "unsetAttributes": ["source", "loading"]
  },
  "documentation": {
    "howTo": null,
    "purpose": null
  },
  "demoSchema": [
    {
      "tag": "runkit-embed",
      "content": "<template>console.log(\"Hello World\");</template>",
      "properties": {
        "mode": "default",
        "nodeVersion": "18.x.x"
      }
    }
  ]
}
