{
  "canScale": false,
  "canEditSource": false,
  "editElement": "editMode",
  "type": "grid",
  "gizmo": {
    "title": "Table",
    "description": "Table-based data for the web.",
    "icon": "editor:border-all",
    "color": "purple",
    "tags": [
      "Instructional",
      "presentation",
      "table",
      "data",
      "layout",
      "grid",
      "csv",
      "spreadsheet",
      "excel"
    ],
    "handles": [],
    "meta": {
      "author": "HAXTheWeb core team",
      "outlineDesigner": true
    }
  },
  "settings": {
    "configure": [
      {
        "property": "rowHeader",
        "title": "Row Header",
        "description": "Treat first row as a header.",
        "inputMethod": "boolean"
      },
      {
        "property": "columnHeader",
        "title": "Column Header",
        "description": "Treat first column as a header.",
        "inputMethod": "boolean"
      },
      {
        "property": "footer",
        "title": "Footer",
        "description": "Treat last row as a footer.",
        "inputMethod": "boolean"
      },
      {
        "property": "sort",
        "title": "Sortable",
        "description": "Allow sorting by column values.",
        "inputMethod": "boolean"
      },
      {
        "property": "filter",
        "title": "Allow Filter",
        "description": "Allow filtering by column values.",
        "inputMethod": "boolean"
      },
      {
        "property": "numericStyles",
        "title": "Numeric Styling",
        "description": "Apply numeric styling to numeric columns.",
        "inputMethod": "boolean"
      },
      {
        "property": "responsive",
        "title": "Responsive",
        "description": "Adjust table layout on small screens.",
        "inputMethod": "boolean"
      }
    ],
    "advanced": [
      {
        "property": "bordered",
        "title": "Bordered",
        "inputMethod": "boolean"
      },
      {
        "property": "condensed",
        "title": "Condense Rows",
        "description": "Reduce row height.",
        "inputMethod": "boolean"
      },
      {
        "property": "striped",
        "title": "Striped Rows",
        "description": "Shade every other row.",
        "inputMethod": "boolean"
      },
      {
        "property": "downloadable",
        "title": "Download Button",
        "description": "Add a button to download the table.",
        "inputMethod": "boolean"
      },
      {
        "property": "copyable",
        "title": "Copy Button",
        "description": "Add a button to copy table CSV data.",
        "inputMethod": "boolean"
      },
      {
        "property": "printable",
        "title": "Print Button",
        "description": "Add a button to print only the table.",
        "inputMethod": "boolean"
      }
    ],
    "developer": [
      {
        "property": "dataCsv",
        "title": "CSV Data",
        "description": "Create a table from an uploaded CSV file.",
        "inputMethod": "fileupload",
        "accepts": "csv"
      }
    ]
  },
  "saveOptions": {
    "unsetAttributes": [
      "__utils",
      "edit-mode",
      "editMode",
      "data",
      "config",
      "dataCsv",
      "data-csv"
    ]
  },
  "demoSchema": [
    {
      "tag": "editable-table",
      "content": "<table><tr><td>one</td><td>two</td></tr><tr><td>three</td><td>four</td></tr></table>",
      "properties": {
        "copyable": true,
        "downloadable": true,
        "printable": true,
        "bordered": true,
        "striped": true,
        "condensed": true
      }
    }
  ]
}
