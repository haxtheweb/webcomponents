{
  "canScale": false,

  "canEditSource": true,
  "type": "grid",
  "gizmo": {
    "title": "Collapsible container",
    "description": "Single expandable and collapsible container.",
    "icon": "icons:view-day",
    "color": "grey",
    "tags": ["Layout"]
  },
  "settings": {
    "configure": [
      {
        "property": "heading",
        "title": "Heading",
        "description": "Text for the collapse.",
        "inputMethod": "textfield"
      },
      {
        "property": "expanded",
        "title": "Expanded",
        "description": "Expand by default.",
        "inputMethod": "boolean"
      },
      {
        "property": "headingButton",
        "title": "Heading Button",
        "description": "Make the entire heading clickable instead of only the icon.",
        "inputMethod": "boolean"
      },
      {
        "property": "icon",
        "title": "Icon",
        "description": "Icon for the expand/collapse toggle button.",
        "inputMethod": "iconpicker"
      },
      {
        "property": "iconExpanded",
        "title": "Icon (when expanded)",
        "description": "Optional icon for the expanded toggle state.",
        "inputMethod": "iconpicker"
      },
      {
        "slot": "",
        "title": "Content",
        "description": "Content for the collapse.",
        "inputMethod": "code-editor",
        "slotWrapper": "p",
        "editMode": {
          "expanded": true,
          "disabled": false
        }
      }
    ],
    "advanced": [
      {
        "property": "tooltip",
        "title": "Tooltip",
        "description": "Tooltip for the expand/collapse toggle button.",
        "inputMethod": "textfield"
      },
      {
        "property": "tooltipExpanded",
        "title": "Tooltip (when expanded)",
        "description": "Tooltip for the expand/collapse button when expanded.",
        "inputMethod": "textfield"
      }
    ]
  },
  "saveOptions": {
    "unsetAttributes": ["expanded"]
  },
  "demoSchema": [
    {
      "tag": "a11y-collapse",
      "properties": {
        "heading": "Heading",
        "headingButton": true
      },
      "content": "<p>Content goes here.</p>"
    }
  ]
}
